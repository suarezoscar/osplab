{
  "name": "@farmacias-guardia/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "seed:cofourense": "set -a && . ./.env && set +a && jiti scripts/seed-cofourense.ts",
    "seed:cofpontevedra": "set -a && . ./.env && set +a && jiti scripts/seed-cofpontevedra.ts",
    "seed:coflugo": "set -a && . ./.env && set +a && jiti scripts/seed-coflugo.ts",
    "seed:cofc": "set -a && . ./.env && set +a && jiti scripts/seed-cofc.ts",
    "seed:all": "pnpm seed:cofourense && pnpm seed:cofpontevedra && pnpm seed:coflugo && pnpm seed:cofc",
    "dev": "pnpm db:start && pnpm wait-on tcp:5432 --timeout 30000 && pnpm prisma:generate && pnpm prisma:migrate:deploy && pnpm nx run-many -t serve --projects=api,web --parallel=2",
    "dev:stop": "pnpm db:stop",
    "prisma:generate": "prisma generate --schema=libs/api/data-access/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --config=prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config=prisma.config.ts",
    "prisma:studio": "prisma studio --schema=libs/api/data-access/prisma/schema.prisma",
    "prisma:db:push": "prisma db push --config=prisma.config.ts",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "22.6.4",
    "@nx/eslint": "22.6.4",
    "@nx/eslint-plugin": "22.6.4",
    "@nx/js": "22.6.4",
    "@nx/nest": "22.6.4",
    "@nx/node": "22.6.4",
    "@nx/web": "22.6.4",
    "@nx/webpack": "22.6.4",
    "@nx/workspace": "22.6.4",
    "@schematics/angular": "~21.2.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/cheerio": "^1.0.0",
    "@types/node": "20.19.9",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "^4.1.2",
    "angular-eslint": "^21.2.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nx": "22.6.4",
    "postcss": "^8.5.8",
    "prettier": "~3.6.2",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/router": "~21.2.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@prisma/client-runtime-utils": "^7.6.0",
    "axios": "^1.6.0",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.1.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "~7.8.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,md,html,css,yml,yaml}": "prettier --write"
  }
}
