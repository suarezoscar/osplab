{
  "name": "api-scraper",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/api/scraper/src",
  "projectType": "library",
  "tags": ["type:feature", "scope:api"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/libs/api/scraper"],
      "options": {
        "command": "vitest run --config libs/api/scraper/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "coverage": {
          "command": "vitest run --coverage --config libs/api/scraper/vitest.config.ts"
        },
        "watch": {
          "command": "vitest --config libs/api/scraper/vitest.config.ts"
        }
      }
    }
  }
}
