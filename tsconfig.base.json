{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "strict": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@farmacias-guardia/api-data-access": ["libs/api/data-access/src/index.ts"],
      "@farmacias-guardia/api-scraper": ["libs/api/scraper/src/index.ts"],
      "@farmacias-guardia/shared-interfaces": ["libs/shared/interfaces/src/index.ts"],
      "@farmacias-guardia/web-ui": ["libs/web/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
