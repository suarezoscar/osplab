{
  "name": "farmacias-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/farmacias-api/src",
  "projectType": "application",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/farmacias-api"],
      "options": {
        "command": "vitest run --config apps/farmacias-api/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "coverage": {
          "command": "vitest run --coverage --config apps/farmacias-api/vitest.config.ts"
        },
        "watch": {
          "command": "vitest --config apps/farmacias-api/vitest.config.ts"
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "apps/farmacias-api"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/farmacias-api/package.json",
        "{workspaceRoot}/dist/apps/farmacias-api/pnpm-lock.yaml"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/apps/farmacias-api/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "farmacias-api:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "farmacias-api:build:development"
        },
        "production": {
          "buildTarget": "farmacias-api:build:production"
        }
      }
    }
  },
  "tags": ["type:app", "scope:farmacias"]
}
