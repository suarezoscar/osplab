# ──────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ──────────────────────────────────────────────────────────────────────────────

# Base de datos PostgreSQL + PostGIS
# Copia este archivo como .env y rellena los valores
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/farmacias_guardia?schema=public"

# Credenciales de Docker Compose (deben coincidir con DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=farmacias_guardia
# DB_PORT=5432

# Puerto del servidor NestJS (opcional, default: 3000)
# PORT=3000

# CORS: origin del frontend en producción (ej: https://farmaciasguardia.es)
# En desarrollo se permite http://localhost:4200 por defecto.
# CORS_ORIGIN=https://farmaciasguardia.es

# API Key para los endpoints de administración (/api/admin/scrape/*)
# Generar con: openssl rand -hex 32
ADMIN_API_KEY=CHANGE_ME

# ──────────────────────────────────────────────────────────────────────────────
# GitHub MCP Server (para ver alertas de Dependabot desde el IDE)
# Crear en: https://github.com/settings/tokens?type=beta
# Permisos necesarios (Fine-grained): Repository > Dependabot alerts (Read)
# ──────────────────────────────────────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_CHANGE_ME
